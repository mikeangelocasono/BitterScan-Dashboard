# ==============================================
# BitterScan Expert Dashboard — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your actual values:
#   cp .env.local.example .env.local
#
# For production (Vercel): set these in
#   Vercel Dashboard → Settings → Environment Variables

# ── Supabase (required) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Admin / Server-only (required for API routes) ──
# NEVER prefix with NEXT_PUBLIC_ — this key bypasses RLS.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Optional ─────────────────────────────────
# NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ── Lingvanex Translation API (required for Disease Library auto-translation) ──
# Get your API key from https://lingvanex.com/
# NEVER prefix with NEXT_PUBLIC_ — this key is server-only.
LINGVANEX_API_KEY=your-lingvanex-api-key-here
